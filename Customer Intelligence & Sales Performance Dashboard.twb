      <column caption='CY Sales' datatype='real' name='[Calculation_0851597058031616]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([Order Date])=[Parameters].[Parameter 0851597059166211] THEN [Sales] END' />
      </column>
      <column caption='PY Sales' datatype='real' name='[Calculation_0851597058633729]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([Order Date])=[Parameters].[Parameter 0851597059166211]-1 THEN [Sales] END' />
      </column>
      <column caption='Year' datatype='integer' name='[Calculation_0851597058924546]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='YEAR([Order Date])' />
      </column>
      <column caption='% Diff Sale' datatype='real' default-format='p0.0%' name='[Calculation_0851597060911108]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Calculation_0851597058031616])-SUM([Calculation_0851597058633729]))/SUM([Calculation_0851597058633729])' />
      </column>
      <column caption='Min/Max Sales' datatype='real' name='[Calculation_0851597067325445]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([Calculation_0851597058031616])=WINDOW_MAX(SUM([Calculation_0851597058031616]))&#13;&#10;THEN SUM([Calculation_0851597058031616])&#13;&#10;ELSEIF SUM([Calculation_0851597058031616])=WINDOW_MIN(SUM([Calculation_0851597058031616]))&#13;&#10;THEN SUM([Calculation_0851597058031616]) &#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='CY Profit' datatype='real' name='[Calculation_0851597088444424]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([Order Date])=[Parameters].[Parameter 0851597059166211] THEN [Profit] END' />
      </column>
      <column caption='PY Profit' datatype='real' name='[Calculation_0851597088612361]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([Order Date])=[Parameters].[Parameter 0851597059166211]-1 THEN [Profit] END' />
      </column>
      <column caption='% Diff Profit' datatype='real' name='[Calculation_0851597088776202]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Calculation_0851597088444424])-SUM([Calculation_0851597088612361]))/SUM([Calculation_0851597088612361])' />
      </column>
      <column caption='Min/Max Profit' datatype='real' name='[Calculation_0851597089107979]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([Calculation_0851597088444424])=WINDOW_MIN(SUM([Calculation_0851597088444424]))&#13;&#10;THEN SUM([Calculation_0851597088444424])&#13;&#10;ELSEIF SUM([Calculation_0851597088444424])=WINDOW_MAX(SUM([Calculation_0851597088444424]))&#13;&#10;THEN SUM([Calculation_0851597088444424]) &#13;&#10;END'>
