    <worksheet name='KPI Sale per Customer'>
      <layout-options>
        <title>
          <formatted-text>
            <run>Total Sale Per Customer&#10;</run>
            <run bold='true' fontsize='20'><![CDATA[<[federated.0lczsrj12e5scx0zpkrjd10lzp23].[sum:Calculation_0851597293522982:qk]>]]></run>
            <run>Æ&#10;</run>
            <run bold='true' fontsize='12'><![CDATA[<[federated.0lczsrj12e5scx0zpkrjd10lzp23].[sum:Calculation_0851597293563943:qk]>]]></run>
            <run bold='true' fontcolor='#898989' fontsize='12'> Vs.PY</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sample - Superstore' name='federated.0lczsrj12e5scx0zpkrjd10lzp23' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Select Year' datatype='integer' default-format='n0;-0' name='[Parameter 0851597059166211]' param-domain-type='list' role='measure' type='quantitative' value='2015'>
              <calculation class='tableau' formula='2015' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0lczsrj12e5scx0zpkrjd10lzp23'>
            <column caption='CY Sales' datatype='real' name='[Calculation_0851597058031616]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date])=[Parameters].[Parameter 0851597059166211] THEN [Sales] END' />
            </column>
            <column caption='PY Sales' datatype='real' name='[Calculation_0851597058633729]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date])=[Parameters].[Parameter 0851597059166211]-1 THEN [Sales] END' />
            </column>
            <column caption='CY Customer' datatype='string' name='[Calculation_0851597282435100]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF YEAR([Order Date])=[Parameters].[Parameter 0851597059166211] THEN [Customer ID] END' />
            </column>
            <column aggregation='CountD' caption='PY Customer' datatype='string' default-role='measure' default-type='quantitative' name='[Calculation_0851597282865181]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF YEAR([Order Date])=[Parameters].[Parameter 0851597059166211]-1 THEN [Customer ID] END' />
            </column>
            <column caption='CY Sales Per Customer' datatype='real' name='[Calculation_0851597283274782]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_0851597058031616])/COUNTD([Calculation_0851597282435100])' />
            </column>
            <column caption='PY Sale per Customer' datatype='real' name='[Calculation_0851597283864607]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_0851597058633729]) / COUNTD([Calculation_0851597282865181])' />
            </column>
            <column caption='Min/Max Sales Per customer' datatype='real' name='[Calculation_0851597284778016]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF&#13;&#10;SUM([Calculation_0851597058031616]) / COUNTD([Calculation_0851597282435100])&#13;&#10;=&#13;&#10;WINDOW_MIN(SUM([Calculation_0851597058031616]) / COUNTD([Calculation_0851597282435100]))&#13;&#10;&#13;&#10;THEN&#13;&#10;SUM([Calculation_0851597058031616]) / COUNTD([Calculation_0851597282435100])&#13;&#10;&#13;&#10;ELSEIF&#13;&#10;SUM([Calculation_0851597058031616]) / COUNTD([Calculation_0851597282435100])&#13;&#10;=&#13;&#10;WINDOW_MAX(SUM([Calculation_0851597058031616]) / COUNTD([Calculation_0851597282435100]))&#13;&#10;&#13;&#10;THEN&#13;&#10;SUM([Calculation_0851597058031616]) / COUNTD([Calculation_0851597282435100])&#13;&#10;&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='% Diff Sale per Customer' datatype='real' name='[Calculation_0851597287088163]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(&#13;&#10;    (SUM([Calculation_0851597058031616]) / COUNTD([Calculation_0851597282435100]))&#13;&#10;    -&#13;&#10;    (SUM([Calculation_0851597058633729]) / COUNTD([Calculation_0851597282865181]))&#13;&#10;)&#13;&#10;/&#13;&#10;(SUM([Calculation_0851597058633729]) / COUNTD([Calculation_0851597282865181]))' />
            </column>
            <column caption='{[CY Sales Per Customer]}' datatype='real' name='[Calculation_0851597293522982]' role='measure' type='quantitative' user:unnamed='Sheet 8'>
              <calculation class='tableau' formula='{[Calculation_0851597283274782]}' />
            </column>
            <column caption='{[% Diff Sale per Customer]}' datatype='real' name='[Calculation_0851597293563943]' role='measure' type='quantitative' user:unnamed='Sheet 8'>
              <calculation class='tableau' formula='{[Calculation_0851597287088163]}' />
            </column>
            <column datatype='string' name='[Customer ID]' role='dimension' type='nominal' />
