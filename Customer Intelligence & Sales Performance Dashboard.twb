      </column>
      <column caption='KPI Sale Avg' datatype='string' name='[Calculation_0851597252374552]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Calculation_0851597058031616])&gt;WINDOW_AVG(SUM([Calculation_0851597058031616]))&#13;&#10;THEN &apos;above&apos; ELSE &apos;below&apos; END'>
